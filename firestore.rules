rules_version = '2';

// ============================================================
//  Talentos-RH — Firestore Security Rules
//
//  Principios:
//  - Cada usuario gestiona SOLO sus propios documentos.
//  - Un empleador NO puede auto-verificarse (campo verified).
//  - Nadie puede auto-cambiarse el rol.
//  - Las acciones de admin pasan por el Admin SDK (servidor), que
//    BYPASSEA estas reglas; por eso aquí no hace falta dar acceso
//    especial al admin desde el cliente.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // El empleador actual está verificado (candado anti vacantes falsas).
    function isVerifiedEmployer() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/employers/$(request.auth.uid))
        && get(/databases/$(database)/documents/employers/$(request.auth.uid)).data.verified == true;
    }

    // --- users/{uid} ---
    match /users/{uid} {
      allow read: if isOwner(uid);
      // Al crear, el rol solo puede ser candidate o employer (no admin).
      allow create: if isOwner(uid)
        && request.resource.data.role in ['candidate', 'employer'];
      // Al actualizar, el usuario NO puede cambiar su propio rol.
      allow update: if isOwner(uid)
        && request.resource.data.role == resource.data.role;
      allow delete: if false;
    }

    // --- candidates/{uid} ---
    match /candidates/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    // --- employers/{uid} ---
    match /employers/{uid} {
      // Los perfiles de empresa pueden ser visibles para usuarios autenticados
      // (necesario para mostrar la empresa en las vacantes, más adelante).
      allow read: if isSignedIn();
      // Al crear, verified DEBE ser false (nadie nace verificado).
      allow create: if isOwner(uid)
        && request.resource.data.verified == false;
      // Al actualizar, el empleador NO puede tocar su propio verified.
      allow update: if isOwner(uid)
        && request.resource.data.verified == resource.data.verified;
      allow delete: if false;
    }

    // --- jobPosts/{jobId} ---
    match /jobPosts/{jobId} {
      // Vacantes publicadas: lectura pública. Borradores: solo su dueño.
      allow read: if resource.data.status == 'open'
        || (isSignedIn() && resource.data.employerId == request.auth.uid);
      // Crear: solo el propio empleador verificado.
      allow create: if isVerifiedEmployer()
        && request.resource.data.employerId == request.auth.uid
        && request.resource.data.status in ['open', 'draft', 'closed'];
      // Editar/borrar: solo el dueño verificado.
      allow update, delete: if isVerifiedEmployer()
        && resource.data.employerId == request.auth.uid;
    }

    // --- applications/{applicationId} ---
    match /applications/{applicationId} {
      // Lectura: el candidato dueño o el empleador de la vacante.
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.candidateId ||
        request.auth.uid == resource.data.employerId
      );
      // Escritura: solo el servidor (Admin SDK), nunca el cliente.
      // Así garantizamos snapshot íntegro, no duplicados y evaluación IA.
      allow write: if false;
    }
  }
}
