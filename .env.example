# ============================================================
#  Talentos-RH — Variables de Entorno (PLANTILLA)
#  Copia este archivo a .env.local y rellena con tus valores.
#  NUNCA subas .env.local al repositorio.
# ============================================================

# ---- Firebase Client SDK (público, se expone al navegador) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Firebase Admin SDK (PRIVADO, solo servidor) ----
# Obtén estos valores del archivo serviceAccountKey.json de Firebase
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# La private key debe ir entre comillas dobles y con los \n literales
FIREBASE_ADMIN_PRIVATE_KEY=""

# ---- Proveedor de IA (evaluación de aplicaciones) ----
# Se usa SOLO en el servidor (API Routes). Nunca en el cliente.
AI_API_KEY=
AI_MODEL=claude-opus-4-8
